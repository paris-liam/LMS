{% comment %}
  lms-new-releases — collection-driven product grid ("New arrivals this week").
  Staff rotates stock by managing the selected collection in admin; the
  homepage follows automatically. The "Browse all" button links to the
  selected collection — the URL is derived, not a setting.
  Desktop: 5-up grid. Tablet: 3-up. Mobile: horizontal scroll-snap row.
{% endcomment %}

{%- liquid
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show
-%}

<div class="lms-new-releases color-{{ section.settings.color_scheme }}" style="--lms-pad-top: {{ section.settings.padding-block-start }}px; --lms-pad-bottom: {{ section.settings.padding-block-end }}px;">
  <div class="lms-container">

    <div class="lms-section-header">
      <div>
        {% render 'lms-eyebrow', text: section.settings.eyebrow %}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.button_label != blank and collection != blank -%}
        <a href="{{ collection.url }}" class="lms-btn lms-btn--outline lms-btn--sm">
          {{- section.settings.button_label -}}
        </a>
      {%- endif -%}
    </div>

    <div class="lms-new-releases__grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'lms-product-card', card_product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Onboarding state: no collection selected yet {%- endcomment -%}
        {%- for i in (1..limit) -%}
          <div class="lms-product-card">
            <div class="lms-product-card__media">
              <div class="lms-product-card__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
            </div>
            <div class="lms-product-card__title">Example title</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</div>

{% stylesheet %}
.lms-new-releases {
  background: var(--color-background, var(--lms-parchment));
  padding-block: var(--lms-pad-top, 24px) var(--lms-pad-bottom, 72px);
}
.lms-new-releases__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 22px;
}
@media (max-width: 1024px) {
  .lms-new-releases__grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 680px) {
  .lms-new-releases__grid {
    display: flex;
    overflow-x: auto;
    gap: 14px;
    padding-bottom: 10px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }
  .lms-new-releases__grid > * {
    flex: 0 0 66%;
    scroll-snap-align: start;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LMS new releases",
  "tag": "section",
  "class": "lms-new-releases-section",
  "settings": [
    { "type": "header", "content": "Heading" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Just dropped"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New arrivals this week"
    },
    { "type": "header", "content": "Products" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Products are shown from this collection in its own sort order. To rotate stock, update the collection — this section follows automatically."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    { "type": "header", "content": "Button" },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Browse all →",
      "info": "Links to the selected collection. Leave blank to hide."
    },
    { "type": "header", "content": "Section style" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    { "name": "LMS new releases" }
  ]
}
{% endschema %}
