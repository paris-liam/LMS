{% comment %}
  lms-promo-card — reusable theme block (/blocks). One component, styled by
  color scheme; ships with two presets: "Rental library" (sage) and
  "Mystery bag" (mahogany + background "?"). Usable inside any section that
  accepts @theme blocks — designed for lms-promo-pair.
{% endcomment %}

<div class="lms-promo-card color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  {%- if block.settings.background_glyph != blank -%}
    <div class="lms-promo-card__glyph" aria-hidden="true">{{ block.settings.background_glyph | slice: 0, 1 }}</div>
  {%- endif -%}

  <div class="lms-promo-card__inner">
    {% render 'lms-eyebrow', text: block.settings.eyebrow, tone: 'parchment' %}

    {%- if block.settings.heading != blank -%}
      <h2 class="lms-promo-card__heading">{{ block.settings.heading }}</h2>
    {%- endif -%}

    {%- if block.settings.body != blank -%}
      <div class="lms-promo-card__body rte">{{ block.settings.body }}</div>
    {%- endif -%}

    <div class="lms-promo-card__foot">
      {%- if block.settings.stat_value != blank -%}
        <div>
          {%- if block.settings.stat_label != blank -%}
            <div class="lms-promo-card__stat-label">{{ block.settings.stat_label }}</div>
          {%- endif -%}
          <div class="lms-promo-card__stat">
            <span class="lms-promo-card__stat-value">{{ block.settings.stat_value }}</span>
            {%- if block.settings.stat_suffix != blank -%}
              <span class="lms-promo-card__stat-suffix">{{ block.settings.stat_suffix }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.button_label != blank -%}
        <a href="{{ block.settings.button_link | default: '#' }}" class="lms-btn lms-btn--outline-inverse lms-btn--md">
          {{- block.settings.button_label -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.lms-promo-card {
  position: relative;
  background: var(--color-background, var(--lms-sage));
  color: var(--color-foreground, var(--lms-parchment));
  border-radius: var(--lms-radius-md);
  padding: 44px 42px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--lms-shadow-sm);
  min-height: 100%;
}
.lms-promo-card__glyph {
  position: absolute;
  right: -6px;
  top: 50%;
  transform: translateY(-50%);
  font-family: var(--lms-font-display);
  font-weight: var(--lms-fw-head-bold);
  font-size: 230px;
  line-height: 1;
  color: color-mix(in oklch, currentColor 6%, transparent);
  pointer-events: none;
  user-select: none;
}
.lms-promo-card__inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100%;
}
.lms-promo-card .lms-eyebrow { display: block; }
.lms-promo-card__heading {
  font-family: var(--lms-font-display);
  font-weight: var(--lms-fw-head-med);
  font-size: 34px;
  line-height: 1.08;
  margin: 12px 0 14px;
  color: inherit;
}
.lms-promo-card__body {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-light);
  font-size: 15px;
  line-height: 1.65;
  color: color-mix(in oklch, currentColor 84%, transparent);
  margin: 0 0 26px;
}
.lms-promo-card__body p { margin: 0 0 1em; }
.lms-promo-card__body p:last-child { margin-bottom: 0; }
.lms-promo-card__foot {
  margin-top: auto;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  padding-top: 22px;
  border-top: var(--lms-border-width) solid color-mix(in oklch, currentColor 24%, transparent);
}
.lms-promo-card__stat-label {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-med);
  font-size: 10px;
  letter-spacing: var(--lms-tracking-eyebrow);
  text-transform: uppercase;
  color: color-mix(in oklch, currentColor 66%, transparent);
  margin-bottom: 4px;
}
.lms-promo-card__stat {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.lms-promo-card__stat-value {
  font-family: var(--lms-font-display);
  font-weight: var(--lms-fw-head-semi);
  font-size: 52px;
  line-height: 1;
}
.lms-promo-card__stat-suffix {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-light);
  font-size: 12px;
  color: color-mix(in oklch, currentColor 70%, transparent);
}
@media screen and (max-width: 549px) {
  .lms-promo-card { padding: 32px 26px; }
  .lms-promo-card__heading { font-size: 28px; }
  .lms-promo-card__stat-value { font-size: 42px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LMS promo card",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The rental library"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not ready to commit? Rent it."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text",
      "default": "<p>A few bucks gets any film home for the week — players included if you need one. Take a chance on something weird, bring it back, tell us what you thought. Free for members, and most of the time, renters become buyers.</p>"
    },
    { "type": "header", "content": "Price callout" },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Small label",
      "default": "Rentals from"
    },
    {
      "type": "text",
      "id": "stat_value",
      "label": "Big number",
      "default": "$4"
    },
    {
      "type": "text",
      "id": "stat_suffix",
      "label": "After the number",
      "default": "/ week · free for members"
    },
    { "type": "header", "content": "Button" },
    {
      "type": "text",
      "id": "button_label",
      "label": "Label",
      "default": "Browse library →"
    },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "header", "content": "Style" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "text",
      "id": "background_glyph",
      "label": "Background character",
      "info": "One large decorative character behind the content (like the “?”). Leave blank for none."
    }
  ],
  "presets": [
    { "name": "Promo card — Rental library" },
    {
      "name": "Promo card — Mystery bag",
      "settings": {
        "eyebrow": "Online · Ships nationwide",
        "heading": "The mystery bag.",
        "body": "<p>We pick, you watch. A bag of films hand-selected by the crew — themed, random, or genre-driven. The best way to discover something you'd never have found on your own.</p>",
        "stat_label": "Starting at",
        "stat_value": "$35",
        "stat_suffix": "",
        "button_label": "Get a bag →",
        "color_scheme": "scheme-2",
        "background_glyph": "?"
      }
    }
  ]
}
{% endschema %}
