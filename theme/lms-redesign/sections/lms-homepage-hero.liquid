<div class="lms-hero color-{{ section.settings.color_scheme }} section spacing-style" style="--padding-block-start:{{ section.settings.padding_top }}px; --padding-block-end:{{ section.settings.padding_bottom }}px;">
  <div class="lms-hero__inner page-width">

    <!-- Left column: copy + CTAs + stats -->
    <div class="lms-hero__left">

      {%- if section.settings.eyebrow != blank -%}
        <p class="lms-eyebrow lms-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="lms-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="lms-hero__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      <div class="lms-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="lms-btn lms-btn--primary lms-btn--lg">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="lms-btn lms-btn--outline lms-btn--lg">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="lms-hero__stats">
        {%- if section.settings.stat_location != blank -%}
          <div class="lms-hero__stat">
            <span class="lms-hero__stat-label">Location</span>
            <span class="lms-hero__stat-value">{{ section.settings.stat_location }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_hours != blank -%}
          <div class="lms-hero__stat">
            <span class="lms-hero__stat-label">Hours</span>
            <span class="lms-hero__stat-value">{{ section.settings.stat_hours }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_membership != blank -%}
          <div class="lms-hero__stat">
            <span class="lms-hero__stat-label">Membership</span>
            <span class="lms-hero__stat-value">{{ section.settings.stat_membership }}</span>
          </div>
        {%- endif -%}
      </div>

    </div>

    <!-- Right column: placeholder (hero art — rotating covers + CRT effect) -->
    <!-- TODO: hero-right-column — rotating cover art + CRT scanline effect. See lms-homepage.dc.html for the design. -->
    <div class="lms-hero__right" aria-hidden="true">
      <div class="lms-hero__placeholder">
        <span class="lms-hero__placeholder-label">Hero art</span>
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .lms-hero {
    background-color: var(--lms-parchment);
    padding-block-start: var(--padding-block-start, 80px);
    padding-block-end: var(--padding-block-end, 64px);
  }

  .lms-hero__inner {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    gap: 52px;
    align-items: center;
  }

  /* --- Left column --- */
  .lms-hero__eyebrow {
    margin: 0 0 20px;
  }

  .lms-hero__heading {
    font-family: var(--lms-font-display);
    font-weight: 600;
    font-size: clamp(46px, 5.6vw, 76px);
    line-height: 1.0;
    letter-spacing: -0.01em;
    color: var(--lms-text-strong);
    margin: 0 0 24px;
  }

  .lms-hero__body {
    font-family: var(--lms-font-mono);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.65;
    color: var(--lms-text-body);
    max-width: 460px;
    margin: 0 0 34px;
  }

  .lms-hero__ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 54px;
  }

  /* --- Shared button base --- */
  .lms-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--lms-font-mono);
    font-weight: var(--lms-fw-mono-med);
    font-size: 14px;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-radius: var(--lms-radius-button);
    transition: background var(--lms-dur-fast) var(--lms-ease-soft),
                color var(--lms-dur-fast) var(--lms-ease-soft),
                border-color var(--lms-dur-fast) var(--lms-ease-soft);
    cursor: pointer;
    white-space: nowrap;
  }

  .lms-btn--lg { padding: 14px 26px; height: 52px; }
  .lms-btn--md { padding: 11px 22px; height: 44px; }
  .lms-btn--sm { padding: 8px 16px;  height: 36px; }

  .lms-btn--primary {
    background: var(--lms-brick);
    color: var(--lms-parchment);
    border: 1.5px solid var(--lms-brick);
  }
  .lms-btn--primary:hover {
    background: var(--lms-brick-dark);
    border-color: var(--lms-brick-dark);
    color: var(--lms-parchment);
  }

  .lms-btn--outline {
    background: transparent;
    color: var(--lms-text-strong);
    border: 1.5px solid var(--lms-border-strong);
  }
  .lms-btn--outline:hover {
    background: var(--lms-text-strong);
    color: var(--lms-parchment);
    border-color: var(--lms-text-strong);
  }

  /* --- Stats strip --- */
  .lms-hero__stats {
    padding-top: 28px;
    border-top: 1.5px solid var(--lms-border-default);
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .lms-hero__stat-label {
    display: block;
    font-family: var(--lms-font-mono);
    font-weight: var(--lms-fw-mono-med);
    font-size: 10px;
    letter-spacing: var(--lms-tracking-eyebrow);
    text-transform: uppercase;
    color: var(--lms-text-muted);
    margin-bottom: 7px;
  }

  .lms-hero__stat-value {
    display: block;
    font-family: var(--lms-font-mono);
    font-size: 14px;
    color: var(--lms-text-strong);
  }

  /* --- Right column placeholder --- */
  .lms-hero__placeholder {
    aspect-ratio: 4 / 5;
    background: var(--lms-mahogany);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(255, 249, 239, 0.12);
  }

  .lms-hero__placeholder-label {
    font-family: var(--lms-font-mono);
    font-weight: var(--lms-fw-mono-med);
    font-size: 11px;
    letter-spacing: var(--lms-tracking-eyebrow);
    text-transform: uppercase;
    color: rgba(255, 249, 239, 0.25);
  }

  /* --- Responsive --- */
  @media screen and (max-width: 989px) {
    .lms-hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .lms-hero__right {
      max-width: 440px;
    }
    .lms-hero__heading {
      font-size: clamp(38px, 8vw, 56px);
    }
    .lms-hero__body {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 549px) {
    .lms-hero__stats {
      gap: 24px;
    }
    .lms-hero__ctas {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LMS Hero",
  "tag": "section",
  "class": "lms-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Now open · Passyunk Ave, South Philly"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Meet me at the<br>movie store.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>A physical-media movie store, curated by people who genuinely love movies. DVD, Blu-ray, 4K, and VHS — new, used, rare, and everything in between. Browse the shelves, rent something, stay a while.</p>"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Label",
      "default": "Join the club →"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Label",
      "default": "Browse the shelves"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Stats strip"
    },
    {
      "type": "text",
      "id": "stat_location",
      "label": "Location",
      "default": "Passyunk Ave · South Philly"
    },
    {
      "type": "text",
      "id": "stat_hours",
      "label": "Hours",
      "default": "Wed – Sat · 10am – 6pm"
    },
    {
      "type": "text",
      "id": "stat_membership",
      "label": "Membership",
      "default": "$100 / year"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "LMS Hero"
    }
  ]
}
{% endschema %}
