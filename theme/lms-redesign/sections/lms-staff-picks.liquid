{% comment %}
  lms-staff-picks — side panel (left) + picks grid (right).

  Picks are driven by a `staff_pick` metaobject (Admin → Content):
    - product     Product reference (poster, title, and link come from it)
    - quote       Multi-line text (the shelf note)
    - staff_name  Single-line text
  Staff updates picks weekly in Admin → Content; the homepage and any
  full-list page render from the same records. Entries display in the
  order returned by the metaobject list; the section shows the first N.
  Storefront access must be enabled on the metaobject definition.
{% endcomment %}

{%- liquid
  assign picks = shop.metaobjects.staff_pick.values
  assign picks_limit = section.settings.picks_to_show
-%}

<div class="lms-staff color-{{ section.settings.color_scheme }}"
  style="--lms-pad-top: {{ section.settings.padding-block-start }}px; --lms-pad-bottom: {{ section.settings.padding-block-end }}px;"
  {{ section.shopify_attributes }}>
  <div class="lms-container">
    <div class="lms-staff__frame">

      <div class="lms-staff__side">
        <div>
          {% render 'lms-eyebrow', text: section.settings.eyebrow %}
          {%- if section.settings.heading != blank -%}
            <h2 class="lms-staff__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <div class="lms-staff__desc rte">{{ section.settings.description }}</div>
          {%- endif -%}
        </div>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link | default: '#' }}" class="lms-staff__textlink">
            {{- section.settings.link_label -}}
          </a>
        {%- endif -%}
      </div>

      <div class="lms-staff__grid">
        {%- assign shown = 0 -%}
        {%- for pick in picks -%}
          {%- if shown >= picks_limit -%}{% break %}{%- endif -%}
          {%- assign pick_product = pick.product.value -%}
          {%- if pick_product -%}
            {%- assign shown = shown | plus: 1 -%}
            <div class="lms-staff__pick">
              <a href="{{ pick_product.url }}" class="lms-staff__poster">
                {%- if pick_product.featured_image -%}
                  {{ pick_product.featured_image
                    | image_url: width: 450
                    | image_tag: widths: '300, 450', sizes: '(max-width: 549px) 45vw, 16vw', loading: 'lazy', alt: pick_product.featured_image.alt | default: pick_product.title }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}
              </a>
              <div class="lms-staff__title">{{ pick_product.title }}</div>
              {%- if pick.quote.value != blank -%}
                <div class="lms-staff__quote">“{{ pick.quote.value }}”</div>
              {%- endif -%}
              {%- if pick.staff_name.value != blank -%}
                <div class="lms-staff__by">— Picked by {{ pick.staff_name.value }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if shown == 0 -%}
          <div class="lms-staff__empty">
            No picks yet. Add staff picks under Admin → Content → Staff picks and they'll appear here automatically.
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
.lms-staff {
  background: var(--color-background, var(--lms-parchment));
  padding-block: var(--lms-pad-top, 0px) var(--lms-pad-bottom, 72px);
}
.lms-staff__frame {
  display: grid;
  grid-template-columns: 300px 1fr;
  border: var(--lms-border-width) solid var(--lms-border-default);
  border-radius: var(--lms-radius-md);
  overflow: hidden;
}
.lms-staff__side {
  background: var(--lms-bg-sunken);
  padding: 38px;
  border-right: var(--lms-border-width) solid var(--lms-border-default);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.lms-staff .lms-eyebrow { display: block; }
.lms-staff__heading {
  font-family: var(--lms-font-display);
  font-style: italic;
  font-weight: var(--lms-fw-head-med);
  font-size: 38px;
  line-height: var(--lms-lh-tight);
  color: var(--lms-text-strong);
  margin: 16px 0;
}
.lms-staff__desc {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-light);
  font-size: 13px;
  line-height: 1.7;
  color: var(--lms-text-muted);
}
.lms-staff__desc p { margin: 0 0 1em; }
.lms-staff__desc p:last-child { margin-bottom: 0; }
.lms-staff__textlink {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-med);
  font-size: 12px;
  letter-spacing: var(--lms-tracking-wide);
  text-transform: uppercase;
  color: var(--lms-brick);
  text-decoration: none;
  margin-top: 24px;
}
.lms-staff__textlink:hover { color: var(--lms-brick-dark); }

.lms-staff__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}
.lms-staff__pick {
  padding: 24px 20px;
  border-right: var(--lms-border-width) solid var(--lms-border-default);
  display: flex;
  flex-direction: column;
}
.lms-staff__pick:last-child { border-right: none; }
.lms-staff__poster {
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: var(--lms-radius-xs);
  overflow: hidden;
  border: var(--lms-border-width) solid var(--lms-border-default);
  box-shadow: var(--lms-shadow-sm);
  margin-bottom: 14px;
  background: var(--lms-parchment-2);
  transition: box-shadow var(--lms-dur-base) var(--lms-ease-soft);
}
.lms-staff__poster:hover { box-shadow: var(--lms-shadow-md); }
.lms-staff__poster img,
.lms-staff__poster svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.lms-staff__title {
  font-family: var(--lms-font-display);
  font-weight: var(--lms-fw-head-med);
  font-size: 15px;
  color: var(--lms-text-strong);
  margin-bottom: 6px;
}
.lms-staff__quote {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-light);
  font-size: 12px;
  line-height: 1.6;
  color: var(--lms-text-muted);
  flex: 1;
}
.lms-staff__by {
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-med);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lms-brick);
  margin-top: 12px;
}
.lms-staff__empty {
  grid-column: 1 / -1;
  padding: 32px;
  font-family: var(--lms-font-mono);
  font-weight: var(--lms-fw-mono-light);
  font-size: 13px;
  color: var(--lms-text-muted);
}

@media screen and (max-width: 989px) {
  .lms-staff__frame { grid-template-columns: 1fr; }
  .lms-staff__side {
    border-right: none;
    border-bottom: var(--lms-border-width) solid var(--lms-border-default);
  }
}
@media screen and (max-width: 549px) {
  .lms-staff__grid { grid-template-columns: 1fr 1fr; }
  .lms-staff__pick {
    border-right: none;
    border-bottom: var(--lms-border-width) solid var(--lms-border-default);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LMS staff picks",
  "tag": "section",
  "class": "lms-staff-picks-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Picks are managed under Admin → Content → Staff picks. Each pick links a product with a shelf note and a staff name."
    },
    { "type": "header", "content": "Side panel" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From the shelves"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Staff picks"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Movies we've been watching, arguing about, and pressing into people's hands. Every pick comes with a hand-written shelf note. Updated weekly.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Full list →",
      "info": "Leave blank to hide."
    },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "header", "content": "Picks" },
    {
      "type": "range",
      "id": "picks_to_show",
      "label": "Picks to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    { "type": "header", "content": "Section style" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    { "name": "LMS staff picks" }
  ]
}
{% endschema %}
